# terminal-army-go environment template. Copy to .env and edit.

# Postgres
DATABASE_URL=postgres://tarmy:tarmy@localhost:5432/tarmy?sslmode=disable

# HTTP server
TARMY_HTTP_ADDR=0.0.0.0:8080
TARMY_PUBLIC_URL=http://localhost:8080

# Auth
TARMY_JWT_SECRET=change-me-please-make-it-long-and-random
TARMY_JWT_TTL_HOURS=168
TARMY_BCRYPT_COST=12

# Scheduler
TARMY_SCHEDULER_INTERVAL_SECONDS=5

# Logging
TARMY_LOG_LEVEL=info
TARMY_LOG_FORMAT=text

# Default universe seed
TARMY_DEFAULT_UNIVERSE_NAME=Genesis
TARMY_DEFAULT_UNIVERSE_GALAXIES=9
TARMY_DEFAULT_UNIVERSE_SYSTEMS=499
TARMY_DEFAULT_UNIVERSE_SPEED_ECONOMY=1
TARMY_DEFAULT_UNIVERSE_SPEED_FLEET=1
TARMY_DEFAULT_UNIVERSE_SPEED_RESEARCH=1
